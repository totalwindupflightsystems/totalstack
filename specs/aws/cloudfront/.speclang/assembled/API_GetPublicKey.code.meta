   <CreatedTime>timestamp</CreatedTime>
   <Id>string</Id>
   <PublicKeyConfig>
      <CallerReference>string</CallerReference>
      <Comment>string</Comment>
      <EncodedKey>string</EncodedKey>
      <Name>string</Name>
   </PublicKeyConfig>
</PublicKey>

