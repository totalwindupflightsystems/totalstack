            <Value>string</Value>
         </SingleHeaderConfig>
         <SingleWeightConfig>
            <SessionStickinessConfig>
               <IdleTTL>integer</IdleTTL>
               <MaximumTTL>integer</MaximumTTL>
            </SessionStickinessConfig>
            <Weight>float</Weight>
         </SingleWeightConfig>
         <Type>string</Type>
      </TrafficConfig>
   </ContinuousDeploymentPolicyConfig>
   <Id>string</Id>
   <LastModifiedTime>timestamp</LastModifiedTime>
</ContinuousDeploymentPolicy>

